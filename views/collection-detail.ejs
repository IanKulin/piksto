<%- include('_header', { page: 'collections', pageTitle: collection.name }) %>

<div class="grid-toolbar" id="grid-toolbar">
  <div class="grid-toolbar__breadcrumb">
    <a href="/collections" class="back-link">&#8592; Collections</a>
    <h1 class="grid-toolbar__title"><%= collection.name %></h1>
  </div>
  <span class="grid-toolbar__count" id="grid-count">
    <%= images.length %> <%= images.length === 1 ? 'image' : 'images' %>
  </span>
  <div class="grid-toolbar__actions" id="grid-toolbar-actions">
    <% if (images.length > 0) { %>
    <button class="btn btn--small btn--secondary" id="grid-select-btn" type="button">Select</button>
    <% } %>
  </div>
</div>

<% if (images.length === 0) { %>
<p class="image-grid__empty">No images yet &mdash; add some from <a href="/allimages">All Images</a></p>
<% } else { %>
<div class="photo-grid image-grid" id="image-grid">
  <% images.forEach(function(img) { %>
  <div class="photo-card image-card" data-id="<%= img.id %>">
    <label class="image-card__select">
      <input type="checkbox" class="image-card__checkbox" value="<%= img.id %>" aria-label="Select image">
    </label>
    <a href="/collections/<%= collection.slug %>/image/<%= img.id %>" class="photo-card__link image-card__link">
      <img src="/image/<%= img.id %>/thumb.jpg" alt="Uploaded image" class="image-card__img" loading="lazy">
      <time class="image-card__date" datetime="<%= img.created_at %>"><%= img.created_at %></time>
    </a>
  </div>
  <% }); %>
</div>
<% } %>

<form id="remove-form" action="/collections/<%= collection.slug %>/remove" method="post"></form>
<form id="delete-form" action="/collections/<%= collection.slug %>/delete" method="post"></form>

<div class="modal-backdrop" id="remove-modal" role="dialog" aria-modal="true" aria-labelledby="remove-modal-msg" hidden>
  <div class="modal">
    <p class="modal__body" id="remove-modal-msg">Remove the selected images from this collection? The images will not be deleted.</p>
    <div class="modal__actions">
      <button id="remove-cancel-btn" class="btn" type="button">Cancel</button>
      <button id="remove-confirm-btn" class="btn btn--secondary" type="button">Remove</button>
    </div>
  </div>
</div>

<div class="modal-backdrop" id="delete-modal" role="dialog" aria-modal="true" aria-labelledby="delete-modal-msg" hidden>
  <div class="modal">
    <p class="modal__body" id="delete-modal-msg">Permanently delete the selected images? They will be removed from all collections and cannot be recovered.</p>
    <div class="modal__actions">
      <button id="delete-cancel-btn" class="btn" type="button">Cancel</button>
      <button id="delete-confirm-btn" class="btn btn--danger" type="button">Delete permanently</button>
    </div>
  </div>
</div>

<%- include('_add-to-collection-modal') %>

<script src="/add-to-collection.js" defer></script>
<script src="/collection-detail.js" defer></script>
  <script src="/menu.js" defer></script>
</main>
</body>
</html>
