<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <title>piksto</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="icon" href="/favicon.ico">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="site-header">
    <a href="/" class="site-title">piksto</a>
    <nav class="site-nav">
      <a href="/" class="nav-link<%= locals.page === 'upload' ? ' nav-link--active' : '' %>">Upload</a>
      <a href="/gallery" class="nav-link<%= locals.page === 'gallery' ? ' nav-link--active' : '' %>">Gallery</a>
    </nav>
    <div class="header-actions">
      <% if (locals.actionsPartial) { %><%- include(locals.actionsPartial) %><% } %>
      <% if (locals.user) { %>
      <form method="POST" action="/logout" style="display:inline">
        <button type="submit" class="btn btn--small">Sign out</button>
      </form>
      <% } %>
    </div>
  </header>
  <main<% if (locals.mainClass) { %> class="<%= locals.mainClass %>"<% } %>>
