<div class="modal-backdrop" id="atc-modal" role="dialog" aria-modal="true" aria-labelledby="atc-modal-title" hidden>
  <div class="modal atc-modal">
    <div class="atc-modal__header">
      <h2 class="atc-modal__title" id="atc-modal-title">Add to collection</h2>
      <button id="atc-close-btn" class="btn btn--small" type="button" aria-label="Close">&#x2715;</button>
    </div>
    <p id="atc-loading" class="atc-status" hidden>Loading&hellip;</p>
    <p id="atc-empty" class="atc-status" hidden>No collections yet &mdash; <a href="/collections">create one first</a></p>
    <ul id="atc-list" class="atc-list" aria-label="Collections"></ul>
  </div>
</div>
