<%- include('_header', { page: 'collections', pageTitle: 'Collections' }) %>

<h1 class="sr-only">Collections</h1>
<div class="grid-toolbar" id="grid-toolbar">
  <span class="grid-toolbar__count" id="grid-count">
    <%= collections.length %> <%= collections.length === 1 ? 'collection' : 'collections' %>
  </span>
  <div class="grid-toolbar__actions" id="grid-toolbar-actions">
    <button class="btn btn--small btn--secondary" id="collections-add-btn" type="button">+</button>
    <% if (collections.length > 0) { %>
    <button class="btn btn--small btn--secondary" id="collections-select-btn" type="button">Select</button>
    <% } %>
  </div>
</div>

<% if (error) { %>
<div class="banner banner--error" id="collections-error" role="alert"><%= error %></div>
<% } %>

<% if (collections.length === 0) { %>
<p class="image-grid__empty">Create your first collection</p>
<% } else { %>
<div class="photo-grid collection-grid" id="collection-grid">
  <% collections.forEach(function(col) { %>
  <div class="photo-card collection-card" data-id="<%= col.id %>">
    <label class="image-card__select">
      <input type="checkbox" class="collection-card__checkbox" value="<%= col.id %>" aria-label="Select collection">
    </label>
    <a href="/collections/<%= col.slug %>" class="photo-card__link collection-card__link">
      <% if (col.cover_image_id) { %>
      <img src="/image/<%= col.cover_image_id %>/thumb.jpg" alt="Collection cover" class="collection-card__cover" loading="lazy">
      <% } else { %>
      <div class="collection-card__placeholder" aria-label="No cover image"></div>
      <% } %>
      <div class="collection-card__info">
        <span class="collection-card__name"><%= col.name %></span>
        <span class="collection-card__count"><%= col.image_count %> <%= col.image_count === 1 ? 'image' : 'images' %></span>
      </div>
    </a>
  </div>
  <% }); %>
</div>
<% } %>

<form id="bulk-delete-form" action="/collections/delete" method="post"></form>

<div class="modal-backdrop" id="bulk-modal" role="dialog" aria-modal="true" aria-labelledby="bulk-modal-msg" hidden>
  <div class="modal">
    <p class="modal__body" id="bulk-modal-msg">Delete the selected collections? Images will not be deleted.</p>
    <div class="modal__actions">
      <button id="bulk-cancel-btn" class="btn" type="button">Cancel</button>
      <button id="bulk-confirm-btn" class="btn btn--danger" type="button">Delete</button>
    </div>
  </div>
</div>

<div class="modal-backdrop" id="create-modal" role="dialog" aria-modal="true" aria-labelledby="create-modal-title" hidden>
  <div class="modal modal--form">
    <h2 class="modal__title" id="create-modal-title">New collection</h2>
    <form id="create-form" action="/collections" method="post" class="modal__form-body">
      <div class="form-group">
        <label class="form-label" for="collection-name-input">Name</label>
        <input class="form-input" type="text" id="collection-name-input" name="name" autocomplete="off" required>
      </div>
      <div id="create-error" class="banner banner--error" hidden></div>
      <button class="btn modal__submit" type="submit">Save</button>
      <button id="create-cancel-btn" class="btn btn--secondary modal__cancel" type="button">Cancel</button>
    </form>
  </div>
</div>

<script src="/collections.js" defer></script>
  <script src="/menu.js" defer></script>
</main>
</body>
</html>
