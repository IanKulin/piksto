<%- include('_header', { mainClass: 'main--image-view', page: context === 'collection' ? 'collections' : 'allimages', pageTitle: 'Image' }) %>

<div id="nav-data" data-prev-url="<%= prevUrl || '' %>" data-next-url="<%= nextUrl || '' %>" hidden></div>

    <div class="image-detail">
      <a href="<%= imageSrc %>" target="_blank" rel="noopener" class="image-detail__link" title="Open in new tab">
        <img src="<%= imageSrc %>" alt="Uploaded image <%= id %>" class="image-detail__img">
      </a>
    </div>

    <div class="image-shelf">
      <div class="image-shelf__back">
        <% if (context === 'collection') { %>
        <a href="/collections/<%= collection.slug %>" class="back-link">&#8592; <%= collection.name %></a>
        <% } else { %>
        <a href="/allimages" class="back-link">&#8592; All Images</a>
        <% } %>
      </div>

      <span class="image-shelf__meta"><%= created_at %></span>

      <div class="image-shelf__nav">
        <% if (prevUrl) { %>
        <a href="<%= prevUrl %>" class="btn btn--small btn--secondary image-shelf__nav-btn">&#8592; Prev</a>
        <% } else { %>
        <button class="btn btn--small btn--secondary image-shelf__nav-btn image-shelf__nav-btn--disabled" disabled>&#8592; Prev</button>
        <% } %>
        <% if (nextUrl) { %>
        <a href="<%= nextUrl %>" class="btn btn--small btn--secondary image-shelf__nav-btn">Next &#8594;</a>
        <% } else { %>
        <button class="btn btn--small btn--secondary image-shelf__nav-btn image-shelf__nav-btn--disabled" disabled>Next &#8594;</button>
        <% } %>
      </div>

      <div class="image-shelf__actions">
        <button type="button" id="add-to-collection-btn" class="btn btn--small btn--secondary">Collections...</button>
        <a href="/image/<%= id %>/download" download class="btn btn--small">Download</a>
        <button type="button" id="open-delete-btn" class="btn btn--small btn--danger">Delete</button>
      </div>
    </div>

    <div id="confirm-delete" class="modal-backdrop" hidden role="dialog" aria-modal="true" aria-labelledby="confirm-delete-title">
      <div class="modal">
        <% if (context === 'collection') { %>
        <p class="modal__body" id="confirm-delete-title">Delete this image? It will be removed from all collections and cannot be undone.</p>
        <% } else { %>
        <p class="modal__body" id="confirm-delete-title">Delete this image? This cannot be undone.</p>
        <% } %>
        <div class="modal__actions">
          <button type="button" id="cancel-delete-btn" class="btn">Cancel</button>
          <form method="POST" action="/image/<%= id %>/delete" class="modal__form">
            <input type="hidden" name="returnTo" value="<%= deleteReturnTo %>">
            <button type="submit" class="btn btn--danger">Delete</button>
          </form>
        </div>
      </div>
    </div>

<%- include('_add-to-collection-modal') %>

<script src="/add-to-collection.js" defer></script>
<script src="/image-detail.js" defer></script>

<%- include('_footer') %>
