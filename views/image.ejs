<%- include('_header', { mainClass: 'main--image-view', pageTitle: 'Image' }) %>

    <div class="image-detail">
      <a href="<%= imageSrc %>" target="_blank" rel="noopener noreferrer" class="image-detail__link" title="Open in new tab">
        <img src="<%= imageSrc %>" alt="Uploaded image <%= id %>" class="image-detail__img">
      </a>
    </div>

    <div class="image-shelf">
      <span class="image-shelf__meta"><%= created_at %></span>

      <div class="image-shelf__nav">
        <% if (prevId) { %>
        <a href="/image/<%= prevId %>" class="btn btn--small btn--secondary image-shelf__nav-btn">&#8592; Prev</a>
        <% } else { %>
        <button class="btn btn--small btn--secondary image-shelf__nav-btn image-shelf__nav-btn--disabled" disabled>&#8592; Prev</button>
        <% } %>
        <% if (nextId) { %>
        <a href="/image/<%= nextId %>" class="btn btn--small btn--secondary image-shelf__nav-btn">Next &#8594;</a>
        <% } else { %>
        <button class="btn btn--small btn--secondary image-shelf__nav-btn image-shelf__nav-btn--disabled" disabled>Next &#8594;</button>
        <% } %>
      </div>

      <div class="image-shelf__actions">
        <a href="/image/<%= id %>/download" download class="btn btn--small">Download</a>
        <button type="button" id="open-delete-btn" class="btn btn--small btn--danger">Delete</button>
      </div>
    </div>

    <div id="confirm-delete" class="modal-backdrop" hidden role="dialog" aria-modal="true" aria-labelledby="confirm-delete-title">
      <div class="modal">
        <p class="modal__body" id="confirm-delete-title">Delete this image? This cannot be undone.</p>
        <div class="modal__actions">
          <button type="button" id="cancel-delete-btn" class="btn">Cancel</button>
          <form method="POST" action="/image/<%= id %>/delete" class="modal__form">
            <button type="submit" class="btn btn--danger">Delete</button>
          </form>
        </div>
      </div>
    </div>

<script src="/image.js" defer></script>
  <script src="/menu.js" defer></script>
</main>
</body>
</html>
