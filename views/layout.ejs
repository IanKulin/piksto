<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <title>photo-sink</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="site-header">
    <span class="site-title">photo-sink</span>
    <nav>
      <a href="/" class="nav-link<%= locals.page === 'upload' ? ' nav-link--active' : '' %>">Upload</a>
      <a href="/gallery" class="nav-link<%= locals.page === 'gallery' ? ' nav-link--active' : '' %>">Gallery</a>
    </nav>
    <% if (locals.headerActions) { %>
    <div class="header-actions"><%- locals.headerActions %></div>
    <% } %>
  </header>
  <main>
    <%- body %>
  </main>
  <footer class="site-footer">
    <span>photo-sink v <%= version %></span>
  </footer>
</body>
</html>
