<%- include('_header', { page: 'allimages', mainClass: 'main--gallery', pageTitle: 'All Images' }) %>

<% if (locals.deleteError) { %>
<div class="banner banner--error" role="alert">Delete failed. Please try again.</div>
<% } %>
<h1 class="sr-only">All Images</h1>
<div class="grid-toolbar" id="grid-toolbar">
  <span class="grid-toolbar__count" id="grid-count">
    <%= images.length %> <%= images.length === 1 ? 'image' : 'images' %>
  </span>
  <div class="grid-toolbar__actions" id="grid-toolbar-actions">
  <% if (images.length > 0) { %>
  <button class="btn btn--small btn--secondary" id="grid-select-btn" type="button">Select</button>
  <% } %>
  </div>
</div>

<div class="gallery-content">
    <% if (images.length === 0) { %>
    <p class="image-grid__empty">No images yet. <a href="/">Upload one!</a></p>
    <% } else { %>
    <div class="photo-grid image-grid" id="image-grid">
      <% images.forEach(function(img) { %>
      <div class="photo-card image-card" data-id="<%= img.id %>">
        <label class="image-card__select">
          <input type="checkbox" class="image-card__checkbox" value="<%= img.id %>" aria-label="Select image">
        </label>
        <a href="/image/<%= img.id %>" class="photo-card__link image-card__link">
          <img src="/image/<%= img.id %>/thumb.jpg" alt="Uploaded image" class="image-card__img" loading="lazy">
          <time class="image-card__date" datetime="<%= img.created_at %>"><%= img.created_at %></time>
        </a>
      </div>
      <% }); %>
    </div>
    <% } %>

    <form id="bulk-delete-form" action="/allimages/delete" method="post"></form>
</div>

<div class="modal-backdrop" id="bulk-modal" role="dialog" aria-modal="true" aria-labelledby="bulk-modal-msg" hidden>
      <div class="modal">
        <p class="modal__body" id="bulk-modal-msg">Delete the selected images? This cannot be undone.</p>
        <div class="modal__actions">
          <button id="bulk-cancel-btn" class="btn" type="button">Cancel</button>
          <button id="bulk-confirm-btn" class="btn btn--danger" type="button">Delete</button>
        </div>
      </div>
    </div>

<%- include('_add-to-collection-modal') %>

    <script src="/add-to-collection.js" defer></script>
    <script src="/image-grid.js" defer></script>
  <script src="/menu.js" defer></script>
</main>
</body>
</html>
