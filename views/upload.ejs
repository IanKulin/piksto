<%- include('_header', { page: 'upload', mainClass: 'main--centered' }) %>

    <div class="card">
      <h1 class="card__title">Upload an Image</h1>

      <% if (locals.success) { %>
      <div class="banner banner--success" role="alert">Image uploaded successfully.</div>
      <% } %>
      <% if (locals.error) { %>
      <div class="banner banner--error" role="alert"><%= locals.error %></div>
      <% } %>

      <form method="POST" action="/upload/file" enctype="multipart/form-data">
        <div class="drop-zone" id="drop-zone">
          <p class="drop-zone__label">Drop or tap to select an image</p>
          <input type="file" accept="image/*" name="image" id="file-input" class="drop-zone__input">
          <div class="drop-zone__file-row">
            <label for="file-input" class="btn btn--secondary">Choose photo</label>
            <span class="drop-zone__filename" id="file-name">no file selected</span>
          </div>
          <button type="submit" class="btn" id="upload-btn" disabled>Upload</button>
        </div>
      </form>

      <div class="upload-divider">
        <span class="upload-divider__label">or fetch from URL</span>
      </div>

      <form method="POST" action="/upload/url">
        <div class="url-row">
          <input type="text" name="url" placeholder="https://…" class="url-input" id="url-input">
          <button type="submit" class="btn" id="fetch-btn">Fetch</button>
        </div>
      </form>
    </div>

<%- include('_footer') %>

<script src="/upload.js" defer></script>
