<%- include('_header', { page: 'upload', mainClass: 'main--centered', pageTitle: 'Upload' }) %>

    <div class="card">
      <h1 class="card__title">Upload an Image</h1>

      <% if (locals.success) { %>
      <div class="banner banner--success" role="alert">Upload complete.</div>
      <% } %>
      <% if (locals.error) { %>
      <div class="banner banner--error" role="alert"><%= locals.error %></div>
      <% } %>

      <form method="POST" action="/upload/file" enctype="multipart/form-data">
        <div class="drop-zone" id="drop-zone">
          <p class="drop-zone__label">Drop or tap to select images</p>
          <input type="file" accept="image/*" name="image" id="file-input" class="drop-zone__input" multiple>
          <div class="drop-zone__file-row">
            <label for="file-input" class="btn btn--secondary" tabindex="0">Choose photos</label>
          </div>
          <div class="drop-zone__file-list" id="file-list" aria-live="polite"></div>
          <button type="submit" class="btn" id="upload-btn" disabled>Upload</button>
        </div>
      </form>

      <div class="upload-divider">
        <span class="upload-divider__label">or fetch from URL</span>
      </div>

      <form method="POST" action="/upload/url">
        <div class="url-row">
          <label for="url-input" class="sr-only">Image URL</label>
          <input type="url" name="url" placeholder="https://…" class="url-input" id="url-input" autofocus>
          <button type="submit" class="btn" id="fetch-btn">Fetch</button>
        </div>
      </form>
    </div>

<script src="/upload.js" defer></script>
  <script src="/menu.js" defer></script>
</main>
</body>
</html>
