<%- include('_header', { page: 'upload' }) %>

    <div class="card">
      <h1 class="card__title">Upload an Image</h1>

      <% if (locals.success) { %>
      <div class="banner banner--success" role="alert">Image uploaded successfully.</div>
      <% } %>
      <% if (locals.error) { %>
      <div class="banner banner--error" role="alert"><%= locals.error %></div>
      <% } %>

      <section class="upload-section">
        <form method="POST" action="/upload/file" enctype="multipart/form-data">
          <div class="drop-zone" id="drop-zone">
            <label for="file-input" class="drop-zone__label">Drop an image here</label>
            <input type="file" accept="image/*" name="image" id="file-input" class="drop-zone__input">
            <button type="submit" class="btn" id="upload-btn" disabled>Upload File</button>
          </div>
        </form>
      </section>

      <section class="upload-section">
        <h2 class="upload-section__heading">Or fetch from URL</h2>
        <form method="POST" action="/upload/url">
          <div class="url-row">
            <input type="text" name="url" placeholder="https://…" class="url-input" id="url-input" autofocus>
            <button type="submit" class="btn" id="fetch-btn">Fetch</button>
          </div>
        </form>
      </section>
    </div>

<%- include('_footer') %>

<script src="/upload.js" defer></script>
