{
  "name": "piksto",
  "version": "0.1.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node --env-file=.env server.js",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test test/unit/**/*.test.js",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "generate-key": "node --eval \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "hash-password": "node --input-type=module --eval \"import bcrypt from 'bcrypt'; const h = await bcrypt.hash(process.argv[1], 10); console.log(h);\" --",
    "docker:hash-password": "node scripts/docker-hash-password.js",
    "docker:build": "docker build -t ghcr.io/iankulin/piksto .",
    "docker:push": "bash scripts/docker-push.sh"
  },
  "keywords": [],
  "author": "",
  "license": "GPL3",
  "type": "module",
  "dependencies": {
    "@iankulin/logger": "^1.1.3",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "file-type": "^22.0.1",
    "multer": "^2.1.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3"
  }
}
